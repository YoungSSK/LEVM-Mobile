<?xml version="1.0" encoding="utf-8"?>
<!--
  Cho phép cleartext HTTP với các dev host (Android emulator + LAN dev IP).
  Production HTTPS vẫn mặc định yêu cầu TLS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
